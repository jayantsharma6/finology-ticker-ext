{
  "manifest_version": 3,
  "name": "Finology Ticker",
  "version": "1.0.0",
  "description": "Search stocks, track markets, detect tickers on any page.",

  "icons": {
    "16": "icons/ticker16.png",
    "48": "icons/ticker48.png",
    "128": "icons/ticker128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/ticker16.png",
      "48": "icons/ticker48.png",
      "128": "icons/ticker128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },


  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ]

}